# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  copy this file to .env and fill in your values
# NEVER commit the real .env file to git
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (pick one: ollama, groq, gemini) ────────────────────────────
LLM_PROVIDER=ollama

# ── Option C: Ollama (DEFAULT — No API key needed, runs locally!) ────────────
# Install from: https://ollama.com
# Run: ollama pull mistral
# Then start: ollama serve
# No API key needed!

# ── Option B: Groq (Free cloud — uncomment and add your key) ────────────────
# Get a free key at: https://console.groq.com
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your-key-here

# ── Option A: Google Gemini (Free cloud — uncomment and add your key) ────────
# Get a free key at: https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIzaSy...your-key-here
